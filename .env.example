# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/filflo

# ── Clerk ─────────────────────────────────────────────
# Backend only
CLERK_SECRET_KEY=sk_test_...
# Frontend only (VITE_ prefix required for Vite to expose to browser)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── API ───────────────────────────────────────────────
PORT=3000
CORS_URLS=http://localhost:5173
APP_BASE_URL=http://localhost:5173

# ── Resend ────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Filflo <invite@your-verified-domain.com>

# ── Bootstrap ─────────────────────────────────────────
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_SUPER_ADMIN_NAME=Filflo Admin
BOOTSTRAP_ORG_NAME=Filflo
